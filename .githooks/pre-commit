#!/bin/bash
set -e

echo "🔍 Running pre-commit checks..."

black --check . --exclude "venv|.git|models" || black . --exclude "venv|.git|models"
pylint agents/ brain/ backtesting/ --disable=missing-docstring --fail-under=7.0 || true
bandit -r . -ll --exclude venv || true
pytest tests/ -v --tb=short --cov=. || exit 1

echo "✅ Pre-commit checks passed!"
